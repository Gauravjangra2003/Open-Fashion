{
  "buildCommand": "npx expo export -p web --output-dir dist --max-workers 2",
  "outputDirectory": "dist",
  "devCommand": "npx expo start --web",
  "cleanUrls": true,
  "framework": null,
  "rewrites": [
    {
      "source": "/((?!_expo|assets|favicon\\.ico).*)",
      "destination": "/index.html"
    }
  ]
}
